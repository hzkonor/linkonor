---
import ButtonsList from "../components/ButtonsList.astro";
import "../style/main.css";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg" href="/pic.svg" />
    <link href="/src/style/main.css" rel="stylesheet" />
    <title>Conor</title>
  </head>

  <body class="bg-zinc-900">
    <div class="text-slate-50 h-full svg-background">
      <div class="w-full bg-slate-900/70">
        <div class="p-4 flex flex-col items-center text-center space-y-2">
          <img src="pic.jpg" alt="Mon avatar" class="rounded-full max-h-40" />
          <p>
            Salut c'est <span id="name">Conor</span>, voici mes différents liens
          </p>
          <!-- Gradient credit to https://ibelick.com/blog/create-animated-text-gradient-with-css -->
          <ButtonsList />

          <p>
            Fait avec 💛 par Conor avec <a
              href="https://astro.build" target="_blank"
              class="underline text-amber-400">Astro.</a
            >
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
